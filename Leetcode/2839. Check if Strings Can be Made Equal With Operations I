class Solution {
    public boolean canBeEqual(String s1, String s2) {
        int count = 0;

        for (int i = 0; i < 4; i++) {
            if (i < 2) {
                if (s1.charAt(i) == s2.charAt(i) || s1.charAt(i) == s2.charAt(i + 2))
                    count++;
            } else {
                if (s1.charAt(i) == s2.charAt(i) || s1.charAt(i) == s2.charAt(i - 2))
                    count++;
            }
        }

        return count == 4;
    }
}
