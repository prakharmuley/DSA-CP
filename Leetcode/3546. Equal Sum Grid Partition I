class Solution {
    public boolean canPartitionGrid(int[][] grid) {

        long sum = 0L;
        for(int[] g : grid)
            for(int x : g)
                sum += x;

        int n = grid.length;
        int m = grid[0].length;

        long[] row = new long[n];
        long[] col = new long[m];

        for(int i=0;i<n;i++)
            for(int j=0;j<m;j++){
                row[i] += grid[i][j];
                col[j] += grid[i][j];
            }

        long prefix = 0;

        for(int i=0;i<n-1;i++){
            prefix += row[i];
            if(prefix * 2 == sum) return true;
        }

        prefix = 0;

        for(int j=0;j<m-1;j++){
            prefix += col[j];
            if(prefix * 2 == sum) return true;
        }

        return false;
    }
}
