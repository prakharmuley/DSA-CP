class Solution {
    public boolean rotateString(String s, String goal) {
        if(s.length()!=goal.length())return false;
        goal+=goal;
        int i=0;
        int j=s.length();
        while(j<goal.length()){
            if(goal.substring(i,j).equals(s)){
                return true;
            }
            j++;
            i++;
        }
        return false;
    }
}
