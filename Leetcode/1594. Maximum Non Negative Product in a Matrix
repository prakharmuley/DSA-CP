class Solution {

    Long[][] max;
    Long[][] min;

    long[] dfs(int i, int j, int[][] grid) {

        int n = grid.length;
        int m = grid[0].length;

        if (i == n-1 && j == m-1)
            return new long[]{grid[i][j], grid[i][j]};

        if (max[i][j] != null)
            return new long[]{max[i][j], min[i][j]};

        long curMax = Long.MIN_VALUE;
        long curMin = Long.MAX_VALUE;

        if (i+1 < n) {
            long[] down = dfs(i+1, j, grid);

            long a = grid[i][j] * down[0];
            long b = grid[i][j] * down[1];

            curMax = Math.max(curMax, Math.max(a,b));
            curMin = Math.min(curMin, Math.min(a,b));
        }

        if (j+1 < m) {
            long[] right = dfs(i, j+1, grid);

            long a = grid[i][j] * right[0];
            long b = grid[i][j] * right[1];

            curMax = Math.max(curMax, Math.max(a,b));
            curMin = Math.min(curMin, Math.min(a,b));
        }

        max[i][j] = curMax;
        min[i][j] = curMin;

        return new long[]{curMax, curMin};
    }

    public int maxProductPath(int[][] grid) {

        int n = grid.length;
        int m = grid[0].length;

        max = new Long[n][m];
        min = new Long[n][m];

        long ans = dfs(0,0,grid)[0];

        if(ans < 0) return -1;

        return (int)(ans % 1000000007);
    }
}
