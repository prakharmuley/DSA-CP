class Solution {
    public int earliestFinishTime(int[] lst, int[] lsd, int[] wst, int[] wsd) {
        long t1 = Long.MAX_VALUE;
        for (int i = 0; i < lst.length; i++) {
            t1 = Math.min(t1, (long) lst[i] + lsd[i]);
        }

        long t2 = Long.MAX_VALUE;
        for (int i = 0; i < wst.length; i++) {
            t2 = Math.min(t2, (long) wst[i] + wsd[i]);
        }

        long ans = Long.MAX_VALUE;

        for (int i = 0; i < wst.length; i++) {
            ans = Math.min(ans, Math.max((long) wst[i], t1) + wsd[i]);
        }

        for (int i = 0; i < lst.length; i++) {
            ans = Math.min(ans, Math.max((long) lst[i], t2) + lsd[i]);
        }

        return (int) ans;
    }
}
