class Solution {
    public int rotatedDigits(int n) {
        int ans = 0;

        for (int i = 1; i <= n; i++) {
            int x = i, s = 0;

            while (x > 0) {
                int d = x % 10;

                if (d == 3 || d == 4 || d == 7) {
                    s = -1;
                    break;
                }

                if (d == 2 || d == 5 || d == 6 || d == 9) {
                    s = 1;
                }

                x /= 10;
            }

            if (s == 1) ans++;
        }

        return ans;
    }
}
