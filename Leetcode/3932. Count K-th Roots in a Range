class Solution {

    public long power(long base, int k, int limit)
    {
        long ans = 1;

        for(int i = 0; i < k; i++)
        {
            ans *= base;

            if(ans > limit)
            {
                return (long)limit + 1;
            }
        }

        return ans;
    }

    public int search(int num, int k, boolean f)
    {
        int ans = 0;
           int l = 0, r = num;
        if(f)
        {
          

            while(l < r)
            {
                int m = l + (r - l) / 2;

                long pow = power(m, k, num);

                if(pow >= num)
                {
                    ans = m;
                    r = m;
                }
                else
                {
                    l = m + 1;
                }
            }
        }
        else
        {

            while(l < r)
            {
                int m = l + (r - l + 1) / 2;

                long pow = power(m, k, num);

                if(pow <= num)
                {
                    ans = m;
                    l = m;
                }
                else
                {
                    r = m - 1;
                }
            }
        }

        return l;
    }

    public int countKthRoots(int l, int r, int k) {

        int floor = search(l, k, true);
        int ceil = search(r, k, false);

        int ans = ceil - floor + 1;

        return Math.max(ans, 0);
    }
}
