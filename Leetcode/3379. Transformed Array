class Solution {
    public int[] constructTransformedArray(int[] nums) {
        int[] ans=new int[nums.length];
        int n=nums.length;
        for(int i=0;i<n;i++)
        {
            int idx=(i+nums[i])%n;
            if(idx<0)
            {
                idx=(idx+n)%n;
            }
            ans[i]=nums[idx];
        }
        return ans;
    }
}
