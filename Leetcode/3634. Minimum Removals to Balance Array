class Solution {
    public int minRemoval(int[] nums, int k) {
        int n = nums.length;
        int ans = n - 1; 
        Arrays.sort(nums);
        
        for (int i = 0; i < n; i++) {
            long target = (long) k * nums[i]; 
            
            int l = i;
            int r = n; 
            
            while (l < r) {
                int mid = l + (r - l) / 2;
                if (nums[mid] <= target) {
                    l = mid + 1;
                } else {
                    r = mid;
                }
            }
            
            ans = Math.min(ans, i + (n - l));
        }
        return ans;
    }
}
