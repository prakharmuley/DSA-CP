class Solution {
    public int[][] reverseSubmatrix(int[][] grid, int x, int y, int k) {

        int m = x + k - 1;

        int n = y + k - 1;

        for(int i = x; i <= (m + x) / 2; i++) {

            for(int j = y; j <= n; j++) {
                int temp = grid[i][j];
                grid[i][j] = grid[m + x - i][j];
                grid[m + x - i][j] = temp;
            }
        }

        return grid;
    }
}
