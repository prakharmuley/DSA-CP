class Solution {
    public int maxScore(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;
        int ans = Integer.MIN_VALUE;

        for (int i = 0; i < m; i++) {
            int curr = grid[i][0];

            for (int j = 1; j < n; j++) {
                ans = Math.max(ans, curr + grid[i][j]);
                curr = Math.max(grid[i][j], curr + grid[i][j]);
            }
        }

        for (int j = 0; j < n; j++) {
            int curr = grid[0][j];

            for (int i = 1; i < m; i++) {
                ans = Math.max(ans, curr + grid[i][j]);
                curr = Math.max(grid[i][j], curr + grid[i][j]);
            }
        }
         for (int i = 1; i < m - 1; i++) {
            for (int j = 1; j <n - 1; j++) {
                ans = Math.max(ans, grid[i][j]);
            }
        }

        return ans;
    }
}
