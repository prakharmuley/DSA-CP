class Solution {
    int maxLength(int arr[]) {
        // code here
         Map<Long,Integer> mp=new HashMap<>();
        mp.put(0L,-1);
        long sum=0L;
        int ans=0;
        for(int i=0;i<arr.length;i++)
        {
            sum+=arr[i];
            if(mp.containsKey(sum))
            {
                ans=Math.max(ans,i-mp.get(sum));
            }
            if(!mp.containsKey(sum))
               mp.put(sum,i);
        }
        return ans;
    }
}
