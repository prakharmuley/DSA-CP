class Solution {
    static ArrayList<Integer> leaders(int arr[]) {
        // code here
         ArrayList<Integer> li = new ArrayList<>();
        int max = 0;
        for (int i = arr.length - 1; i >= 0; i--) {
            if (arr[i] >= max) {
                max = arr[i];
                li.add(max);
            }
        }
         Collections.reverse(li);
        
        return li;
    }
}
