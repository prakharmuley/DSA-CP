class Solution {
    public long subarrayXor(int arr[], int k) {
        // code here
         Map<Long,Integer> mp=new HashMap<>();
        mp.put(0L,1);
        long sum=0L;
        int ans=0;
        for(int i=0;i<arr.length;i++)
        {
            sum^=arr[i];
            if(mp.containsKey(sum^k))
            {
                ans+=mp.get(sum^k);
            }
            
               mp.put(sum,mp.getOrDefault(sum,0)+1);
        }
        return ans;
        
    }
}
