class Solution {
    public List<Integer> majorityElement(int[] nums) {
        List<Integer> list=new ArrayList<>(); 
        int cnt1=0,cnt2=0;
        int prev1=0;
        int prev2=0;
        int f1=0;
        int f2=0;
        int n=nums.length;
        for(int x: nums)
        {
            if(prev1==x)
            {
                    
                     f1++;
            }
            else if(prev2==x)
            {
               f2++;
            }
            else if(f1==0)
            {
                prev1=x;
                f1=1;
            }
            else if(f2==0)
            {
                prev2=x;
                f2=1;
            }
            else 
            {
                f1--;
                f2--;
            }
        }
        f1=0;
        f2=0;
        for(int x: nums)
        {
            if(x==prev1)
            {
                f1++;
            }
            else if(x==prev2)
            {
                f2++;
            }
        }
        if(f1>nums.length/3) list.add(prev1);
        if(f2>nums.length/3) list.add(prev2);
        return list;
    }
}

